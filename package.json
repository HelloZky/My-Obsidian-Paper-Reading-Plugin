{
  "name": "obsidian-paper-reading",
  "version": "0.1.0",
  "description": "Obsidian paper note browser plugin",
  "main": "main.js",
  "scripts": {
    "build": "node generate-data.mjs && tsc -noEmit -skipLibCheck && node esbuild.config.mjs --production",
    "dev": "node generate-data.mjs && node esbuild.config.mjs --watch",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.25.0",
    "obsidian": "^1.5.12",
    "typescript": "^5.4.2"
  }
}
